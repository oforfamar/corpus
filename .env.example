# Authelia OIDC issuer URL (no trailing slash)
# Example: https://auth.yourdomain.com
AUTHELIA_ISSUER=https://auth.yourdomain.com

# OIDC client credentials — register these in your Authelia config
OIDC_CLIENT_ID=corpus
OIDC_CLIENT_SECRET=your-client-secret-here

# The public base URL of this app (used for OIDC redirect URI)
BASE_URL=http://localhost:3000

# A long random string used to sign session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port to listen on (optional, defaults to 3000)
# PORT=3000

# Set to 'true' to bypass OIDC authentication entirely (development only)
# When enabled, all requests are treated as a fake "Dev User" — never use in production
AUTH_BYPASS=false
